            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/mdm/dict/global/type/delete": {
      "post": {
        "tags": [
          "全局字典"
        ],
        "summary": "删除全局字典类型",
        "description": "删除平台级全局空字典类型",
        "operationId": "deleteGlobalType",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GlobalDictTypeDeleteReqDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RVoid"
                }
              }
            }
          }
        }
      }
    },
    "/api/mdm/dict/global/type/create": {
      "post": {
        "tags": [
          "全局字典"
        ],
        "summary": "新增全局字典类型",
        "description": "新增平台级全局字典类型",
        "operationId": "createGlobalType",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
