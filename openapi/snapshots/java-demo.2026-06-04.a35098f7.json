{
  "openapi": "3.0.1",
  "info": {
    "title": "track-bench API 文档",
    "description": "track-bench 项目接口文档",
    "contact": {
      "name": "track-bench"
    },
    "version": "v1"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "全局字典",
      "description": "平台级全局字典维护与查询相关接口"
    },
    {
      "name": "文件存储",
      "description": "文件上传、删除、临时访问地址与直传凭证相关接口"
    }
  ],
  "paths": {
    "/api/mdm/dict/global/types/list": {
      "post": {
        "tags": [
          "全局字典"
        ],
        "summary": "查询全局字典列表",
        "description": "查询平台级全局字典类型列表",
        "operationId": "listGlobalTypes",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/GlobalDictTypeListReqDTO"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/RPageResultGlobalDictTypeRspDTO"
                }
              }
            }
          }
        }
      }
    },
    "/api/mdm/dict/global/type/update": {
      "post": {
        "tags": [
          "全局字典"
        ],
        "summary": "修改全局字典类型",
