server {
    listen 80;
    server_name localhost;
    client_max_body_size 1000M;
    absolute_redirect off;

    gzip on;
    gzip_min_length 1k;
    gzip_comp_level 2;
    gzip_types text/plain text/css text/javascript application/javascript application/x-javascript application/json application/xml image/svg+xml;
    gzip_vary on;

    proxy_send_timeout 3m;
    proxy_read_timeout 3m;
    proxy_connect_timeout 3m;

    root /usr/share/nginx/html;
    index index.html;

    location = / {
        return 302 /tanstack-start-admin/;
    }

    location = /tanstack-start-admin {
        return 301 /tanstack-start-admin/;
    }

    location = /tanstack-start-admin/version.js {
        add_header Cache-Control "no-store";
        try_files $uri =404;
    }

    location ~* ^/tanstack-start-admin/.+\.(?:js|css|woff2?|png|jpg|jpeg|gif|svg|ico)$ {
        try_files $uri =404;
        expires 1y;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    location /tanstack-start-admin/ {
        try_files $uri $uri/ /tanstack-start-admin/index.html;
    }

    location / {
        return 404;
    }
}
