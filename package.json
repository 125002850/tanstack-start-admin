{
  "name": "tanstack-start-admin",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "vite dev",
    "build": "vite build",
    "bundle:check": "node scripts/check-bundle-budget.mjs dist",
    "analyze": "ANALYZE=true vite build",
    "preview": "vite preview",
    "openapi:fetch": "npx openapi-client fetch-spec",
    "codegen": "npx openapi-client generate",
    "codegen:check": "pnpm codegen && pnpm exec tsc --noEmit",
    "api": "pnpm openapi:fetch && pnpm codegen",
    "api:check": "pnpm codegen:check",
    "lint:commit": "commitlint",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "tsc --noEmit",
    "check": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test:unit": "vitest run",
    "pretest:e2e:smoke": "pnpm run build",
    "test:e2e:smoke": "NO_PROXY=127.0.0.1,localhost no_proxy=127.0.0.1,localhost playwright test"
  },
